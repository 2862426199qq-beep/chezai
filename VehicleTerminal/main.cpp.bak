#include "mainwindow.h"
#include <QApplication>
#include "clock.h"
#include <QDebug>
#include <stdio.h>

int main(int argc, char *argv[])
{
    printf("main: starting...\n");
    fflush(stdout);
    
    // 暂时禁用虚拟键盘，测试是否是它导致崩溃
    // qputenv("QT_IM_MODULE", QByteArray("qtvirtualkeyboard"));
    
    printf("main: creating QApplication...\n");
    fflush(stdout);
    QApplication a(argc, argv);
    
    printf("main: creating MainWindow...\n");
    fflush(stdout);
    MainWindow w;
    
    printf("main: showing MainWindow...\n");
    fflush(stdout);
    w.show();
    
    printf("main: entering event loop...\n");
    fflush(stdout);
    return a.exec();
}
